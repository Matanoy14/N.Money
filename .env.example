# ── Supabase ─────────────────────────────────────────────────────────────────
# Copy these from your Supabase project → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Stripe billing (web subscription) ────────────────────────────────────────
# These are NOT set in this file — set them as Supabase Edge Function secrets:
#   supabase secrets set STRIPE_SECRET_KEY=sk_live_…
#   supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_…
#   supabase secrets set STRIPE_PRICE_PERSONAL=price_…
#   supabase secrets set STRIPE_PRICE_COUPLE=price_…
#   supabase secrets set STRIPE_PRICE_FAMILY=price_…
#   supabase secrets set APP_URL=https://your-domain.com
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY=…  (needed by webhook only)
#
# The Stripe SECRET key must never appear in frontend code or .env.local.
# No VITE_STRIPE_* vars are needed — the checkout/portal flows are server-side.

# ── Invite links ──────────────────────────────────────────────────────────────
# The public URL of your deployed app. Used to build shareable invite links.
#
# Leave empty during local development — invite links will fall back to
# window.location.origin and the UI will show a warning about link scope.
#
# Examples:
#   Production:  VITE_PUBLIC_APP_URL=https://app.nmoney.co.il
#   ngrok tunnel: VITE_PUBLIC_APP_URL=https://abcd-1234.ngrok-free.app
#
# For same-device testing (localhost):
#   - Leave this empty. Run: npm run dev
#   - Invite links will say localhost — only usable on this machine.
#
# For same-Wi-Fi phone testing (LAN):
#   - Leave this empty. Run: npm run dev:lan
#   - Vite prints a LAN URL like http://192.168.1.5:5173
#   - Use THAT URL to open the app on your phone AND to copy invite links.
#   - Invite links will use the LAN IP — usable by any device on the same network.
#
# For external sharing (different network / real users):
#   - Deploy the app, or use a tunnel tool like ngrok / Cloudflare Tunnel.
#   - Set VITE_PUBLIC_APP_URL to the public URL before building.
VITE_PUBLIC_APP_URL=
